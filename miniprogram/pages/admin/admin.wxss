.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 管理网格 */
.admin-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.admin-card {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.admin-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}

.admin-text {
  font-size: 28rpx;
  color: #333;
}

/* 区块 */
.section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: none;
}

.action-btn.primary {
  background: #4CAF50;
  color: white;
}

.action-btn::after {
  border: none;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}
