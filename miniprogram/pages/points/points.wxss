.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 积分头部 */
.points-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: white;
  text-align: center;
}

.points-title {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.points-balance {
  margin-bottom: 20rpx;
}

.balance-number {
  font-size: 80rpx;
  font-weight: bold;
  display: block;
}

.balance-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.total-points {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-card {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.action-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 28rpx;
  color: #333;
}

/* 会员等级卡片 */
.level-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.level-title {
  font-size: 28rpx;
  color: #999;
}

.level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.level-progress {
  margin-top: 20rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
}

/* 区块 */
.section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
}

.filter-tab {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
}

.filter-tab.active {
  background: #667eea;
  color: white;
}

/* 积分记录列表 */
.records-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  flex-direction: column;
}

.record-source {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-right {
  display: flex;
  align-items: baseline;
}

.record-type {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.record-right.positive .record-type,
.record-right.positive .record-amount {
  color: #4CAF50;
}

.record-right.negative .record-type,
.record-right.negative .record-amount {
  color: #ff6b6b;
}

/* 空状态 */
.empty, .loading, .load-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.load-more {
  background: #f9f9f9;
  border-radius: 16rpx;
  margin-top: 20rpx;
}
