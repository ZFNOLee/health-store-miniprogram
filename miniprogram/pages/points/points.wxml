<view class="container">
  <!-- 积分概览 -->
  <view class="points-header">
    <view class="points-title">我的积分</view>
    <view class="points-balance">
      <text class="balance-number">{{availablePoints}}</text>
      <text class="balance-label">可用积分</text>
    </view>
    <view class="total-points">
      累计获得：{{totalPoints}} 积分
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-card" bindtap="goToSignin">
      <text class="action-icon">📅</text>
      <text class="action-text">每日签到</text>
    </view>
    <view class="action-card" bindtap="goToExchange">
      <text class="action-icon">🎁</text>
      <text class="action-text">积分兑换</text>
    </view>
  </view>

  <!-- 会员等级 -->
  <view class="level-card">
    <view class="level-header">
      <text class="level-title">当前等级</text>
      <text class="level-name">{{memberLevelName}}</text>
    </view>
    <view class="level-progress">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <text class="progress-text">还需 {{nextLevelPoints}} 积分升级</text>
    </view>
  </view>

  <!-- 积分明细 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">积分明细</text>
      <view class="filter-tabs">
        <text class="filter-tab {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">全部</text>
        <text class="filter-tab {{filterType === 'earn' ? 'active' : ''}}" bindtap="setFilter" data-type="earn">获得</text>
        <text class="filter-tab {{filterType === 'spend' ? 'active' : ''}}" bindtap="setFilter" data-type="spend">消耗</text>
      </view>
    </view>

    <view class="records-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-left">
          <text class="record-source">{{item.source}}</text>
          <text class="record-time">{{item.created_at}}</text>
        </view>
        <view class="record-right {{item.type === 'earn' ? 'positive' : 'negative'}}">
          <text class="record-type">{{item.type === 'earn' ? '+' : '-'}}</text>
          <text class="record-amount">{{item.amount}}</text>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{records.length === 0 && !loading}}">
      <text class="empty-text">暂无积分记录</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text>加载更多</text>
    </view>
  </view>
</view>
