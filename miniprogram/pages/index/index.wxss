.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 签到卡片 */
.checkin-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: white;
}

.checkin-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.checkin-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.checkin-btn {
  background: white;
  color: #667eea;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-weight: bold;
  font-size: 28rpx;
}

.checkin-btn.checked {
  background: #e0e0e0;
  color: #999;
}

/* 用户概览 */
.user-overview {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  justify-content: space-around;
}

.info-item {
  text-align: center;
}

.info-item .label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.info-item .value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.info-item .value.highlight {
  color: #ff6b6b;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-item .icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-item .text {
  font-size: 24rpx;
  color: #666;
}

/* 区块 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  background: #f9f9f9;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-img {
  width: 100%;
  height: 200rpx;
  background: #eee;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.points {
  font-size: 24rpx;
  color: #ff9f43;
  background: #fff3e0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
